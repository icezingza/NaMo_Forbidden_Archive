# 🔓 NaMo Forbidden Archive - configuration Template
# Copy this file to '.env' and fill in your values.

# --- 🎯 CORE LLM CONFIG ---
# Choose your provider and model. DeepSeek, Groq, or Local models are recommended for NSFW.
NAMO_LLM_ENABLED=1
OPENAI_API_KEY=your_api_key_here

# Model Identification (e.g., deepseek-chat, llama3-70b-8192, gpt-4o-mini)
NAMO_LLM_MODEL=gpt-4o-mini
NAMO_LLM_PROVIDER=primary

# Provider Base URL (Leave blank for official OpenAI)
# Groq: https://api.groq.com/openai/v1
# DeepSeek: https://api.deepseek.com
# Ollama: http://localhost:11434/v1
NAMO_LLM_BASE_URL=

# --- 🔓 FORBIDDEN UNLOCK (Dark Mode) ---
# Set to '0' to enable the unchained persona experience
SAFETY_FILTER_ENABLED=0
NSFW_ALLOWED=1

# --- 🧠 BRAIN PARAMETERS ---
NAMO_LLM_TEMPERATURE=0.9
NAMO_LLM_MAX_TOKENS=350
NAMO_LLM_MEMORY_TURNS=10
NAMO_LLM_CONTEXT_WINDOW=8192

# --- 🎤 ELEVENLABS TTS (Optional) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=Rachel

# --- 🌐 SYSTEM ---
APP_PORT=8001
DEBUG=False

# --- 🤖 SENSORY EXPANSION (TELEGRAM) ---
TELEGRAM_TOKEN=

# --- 🗄️ KNOWLEDGE GRAPH & VECTOR DB ---
QDRANT_URL=
NEO4J_URI=
