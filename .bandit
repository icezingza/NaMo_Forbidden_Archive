[bandit]
# Directories excluded from scanning:
#   tests            - assert usage and fake test tokens are expected here
#   templates        - refactor/experimental templates, not imported by the app
#   Archived_Assets  - archived legacy files
#   Documentation    - legacy docs
#   namo_forbidden_archive - duplicate legacy tree (excluded from ruff too)
exclude = ./tests,./templates,./Archived_Assets,./Documentation,./namo_forbidden_archive
# Skipped checks (justified):
#   B311 - random is used for dialogue/persona variety, never for security or crypto
#   B110 - try/except/pass implements intentional graceful degradation for optional services
#   B615 - transformers from_pretrained() calls are optional model loads guarded by a
#          try/except import; revision pinning is out of scope for these experimental engines
skips = B311,B110,B615
